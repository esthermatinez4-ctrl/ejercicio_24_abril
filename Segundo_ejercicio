import requests
import json
import time

def obtener_chiste():
    url = "https://api.chucknorris.io/jokes/random"
    respuesta = requests.get(url)

    if respuesta.status_code == 200:
        datos = respuesta.json()
        return datos["value"]   # El chiste está en "value"
    else:
        return "Error al obtener el chiste."

def obtener_categorias():
    url = "https://api.chucknorris.io/jokes/categories"
    respuesta = requests.get(url)

    if respuesta.status_code == 200:
        return respuesta.json()
    else:
        return []


def chiste_por_categoria(categoria):
    url = f"https://api.chucknorris.io/jokes/random?category={categoria}"
    respuesta = requests.get(url)

    if respuesta.status_code == 200:
        datos = respuesta.json()
        return datos["value"]
    else:
        return "Error al obtener el chiste por categoría."


def menu():
    while True:
        print("\n=== MENÚ CHUCK NORRIS API ===")
        print("1. Ver un chiste aleatorio")
        print("2. Ver categorías disponibles")
        print("3. Elegir una categoría y ver un chiste")
        print("4. Salir")

        opcion = input("Elige una opción: ")

        if opcion == "1":
            print("\nChiste aleatorio:")
            print(obtener_chiste())

        elif opcion == "2":
            categorias = obtener_categorias()
            print("\nCategorías disponibles:")
            for c in categorias:
                print(f"- {c}")

        elif opcion == "3":
            categorias = obtener_categorias()
            print("\nElige una categoría:")
            for c in categorias:
                print(f"- {c}")

            cat = input("\nEscribe la categoría: ").lower()

            if cat in categorias:
                print("\nChiste de la categoría", cat)
                print(chiste_por_categoria(cat))
            else:
                print("Categoría no válida.")

        elif opcion == "4":
            print("Saliendo del programa...")
            time.sleep(1)
            break

        else:
            print("Opción no válida.")


menu()
